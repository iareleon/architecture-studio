# Copy to knowledge-os.env (or source from shell profile) and adjust paths.
# See docs/knowledge-os.md

# SkillsLoom install (skills live under $SKILLSLOOM_DIR/skills/)
export SKILLSLOOM_DIR="${SKILLSLOOM_DIR:-$HOME/.skillsloom}"
# Legacy alias (optional): export SKILLMANAGER_DIR="$SKILLSLOOM_DIR"

# Obsidian layout
export OBSIDIAN_ROOT="${OBSIDIAN_ROOT:-$HOME/Obsidian}"
export OBSIDIAN_META="${OBSIDIAN_META:-$OBSIDIAN_ROOT/meta}"

# Optional: separate choreokit / Knowledge OS op-skills tree (inbox-classifier, super-wiki-sync, etc.)
# export CHOREOKIT_DIR="$HOME/choreokit"
